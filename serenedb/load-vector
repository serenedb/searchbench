#!/usr/bin/env bash
# SereneDB: ingest base vectors + build one IVF index config, print build-metrics
# JSON on stdout (logs -> stderr). Called once per build config by the driver,
# which passes the config as VECTOR_INGEST_ARGS (e.g. "--quant sq8 --nlist 4096").
#
# Default load path is COPY over pgwire (no file mount needed); --load-via parquet
# uses read_parquet CTAS but needs the staged parquet inside a serened-visible
# mount, so it's opt-in.
set -euo pipefail
cd "$(dirname "$0")"

: "${SEARCHBENCH_DATA_DIR:?}"; : "${SEARCHBENCH_VECTOR_DATASET:?}"; : "${PGPORT:?}"
: "${VECTOR_K:=10}"
LIB_DIR="$(cd ../lib && pwd)"

extra=(); [[ -n "${VECTOR_NB:-}" ]] && extra+=(--nb "$VECTOR_NB")
[[ -n "${VECTOR_NQ:-}" ]] && extra+=(--nq "$VECTOR_NQ")

# VECTOR_INGEST_ARGS is intentionally word-split into flags (no spaces in values).
exec "${SEARCHBENCH_PYTHON:-python3}" "${LIB_DIR}/vector_ingest.py" \
    --engine serenedb --dataset "$SEARCHBENCH_VECTOR_DATASET" \
    --data-dir "$SEARCHBENCH_DATA_DIR" --port "$PGPORT" \
    --k "$VECTOR_K" --table vec --index vec_idx \
    --workdir "${SEARCHBENCH_WORKDIR:-${SEARCHBENCH_DATA_DIR}/vec_work}" \
    "${extra[@]}" ${VECTOR_INGEST_ARGS:-}
