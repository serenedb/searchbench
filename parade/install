#!/usr/bin/env bash
# ParadeDB adapter setup. Runs before every benchmark; tears down container +
# data volume so leftover table/BM25 index don't yield a bogus fast load_time.
#
# ./load reads parquet via a serened container (SERENED_IMAGE); nothing to do here.
set -euo pipefail
source "$(dirname "$0")/common.sh"

command -v docker >/dev/null || { echo "docker not found on PATH" >&2; exit 1; }
command -v psql   >/dev/null || { echo "psql not found on PATH"   >&2; exit 1; }
command -v jq     >/dev/null || { echo "jq not found on PATH"     >&2; exit 1; }
docker info >/dev/null 2>&1  || { echo "docker daemon not reachable" >&2; exit 1; }

# Force-remove container + volume so ./start is fresh and load_time reflects real work.
docker rm -f "$PARADE_CONTAINER" >/dev/null 2>&1 || true
# Wipe host bind-mount dir via root container (Postgres owns files as its uid, host
# rm hits EPERM). Also drop stale named volume from pre-bind-mount layout.
docker volume rm -f searchbench-paradedb-data >/dev/null 2>&1 || true
if [[ -d "$PARADE_DATA_DIR" ]]; then
    docker run --rm -v "${PARADE_DATA_DIR}:/data" --entrypoint sh alpine \
        -c 'rm -rf /data/..?* /data/.[!.]* /data/* 2>/dev/null' >/dev/null 2>&1 || true
fi
