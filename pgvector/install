#!/usr/bin/env bash
# One-time setup: pull image, wipe container + data dir so each run rebuilds clean.
set -euo pipefail
source "$(dirname "$0")/common.sh"

command -v docker >/dev/null || { echo "docker not found on PATH" >&2; exit 1; }
command -v psql   >/dev/null || { echo "psql not found on PATH"   >&2; exit 1; }
command -v jq     >/dev/null || { echo "jq not found on PATH"     >&2; exit 1; }
docker info >/dev/null 2>&1  || { echo "docker daemon not reachable" >&2; exit 1; }

echo "pgvector backend: docker ($PGV_IMAGE)"
docker pull --quiet "$PGV_IMAGE" >/dev/null

docker rm -f "$PGV_CONTAINER" >/dev/null 2>&1 || true
# Postgres owns the bind-mount dir as its own uid (host rm hits EPERM), so clear
# via a throwaway root container.
if [[ -d "$PGV_DATA_DIR" ]]; then
    docker run --rm -v "${PGV_DATA_DIR}:/data" --entrypoint sh alpine \
        -c 'rm -rf /data/..?* /data/.[!.]* /data/* 2>/dev/null' >/dev/null 2>&1 || true
fi
