#!/usr/bin/env bash
# Inline every engine's results/*.json into ui/data.js as window.SEARCHBENCH_DATA,
# tagging each doc with `queries` (executed query text, one per result row).
# data.js is loaded via <script src> so index.html works over file:// too.
# Re-run whenever an engine produces new results:  ./ui/build
set -euo pipefail

cd "$(dirname "$0")/.."   # repo root

# Query source files in result-row order. Elasticsearch runs a hybrid benchmark;
# other engines feed one queries.* file read top-to-bottom.
engine_query_files() {
    local ed="$1" qf
    # ES has both queries.dsl (the one it runs) and queries.esql (reference);
    # pick .dsl specifically so rows align -- glob would double-count both.
    if [[ -f "$ed/queries.dsl" ]]; then
        printf '%s\n' "$ed/queries.dsl"
    elif [[ -f "$ed/queries.esql" ]]; then
        printf '%s\n' "$ed/queries.esql"
    elif compgen -G "$ed/queries.*" >/dev/null 2>&1; then
        for qf in "$ed"/queries.*; do [[ -e "$qf" ]] && printf '%s\n' "$qf"; done
    elif [[ -f "$ed/queries.esql" && -f "$ed/queries.dsl" ]]; then
        printf '%s\n%s\n' "$ed/queries.esql" "$ed/queries.dsl"
    else
        for qf in "$ed"/queries.*; do [[ -e "$qf" ]] && printf '%s\n' "$qf"; done
    fi
}

# JSON array of an engine's queries: strip comment (-- # //) and blank lines,
# keep the rest verbatim in order -- same as the driver.
queries_json() {
    local ed="$1" qf
    {
        while IFS= read -r qf; do
            [[ -n "$qf" ]] || continue
            grep -vE '^[[:space:]]*(--|#|//|$)' "$qf" || true
        done < <(engine_query_files "$ed")
    } | jq -Rsc 'split("\n") | map(select(length > 0))'
}

shopt -s nullglob
files=( */results/*.json )
shopt -u nullglob

out="ui/data.js"
{
    printf '// Generated by ui/build -- do not edit by hand. Run ./ui/build to refresh.\n'
    printf 'window.SEARCHBENCH_DATA = [\n'
    first=1
    for f in "${files[@]}"; do
        [[ $first -eq 0 ]] && printf ',\n'
        first=0
        engine="${f%%/*}"
        q="$(queries_json "$engine")"
        jq -c --arg src "$f" --argjson queries "$q" '. + {_source: $src, queries: $queries}' "$f"
        # Warn (don't fail) on query/result count mismatch -- usually a parse gap.
        rlen=$(jq '.result | length' "$f")
        qlen=$(printf '%s' "$q" | jq 'length')
        [[ "$rlen" == "$qlen" ]] || echo "  WARN: $f has $rlen result rows but $qlen queries for '$engine'" >&2
    done
    printf '\n];\n'
} > "$out"

echo "wrote $out from ${#files[@]} result file(s)" >&2
