#!/usr/bin/env bash
# Inline every engine's results-vector/*.json into vector-ui/data.js as
# window.VECTORBENCH_DATA. Mirrors ui/build (text track). data.js is loaded via
# <script src> so vector-ui/index.html works over file:// too.
# Re-run whenever an engine produces new vector results:  ./vector-ui/build
set -euo pipefail
cd "$(dirname "$0")/.."   # repo root

shopt -s nullglob
files=( */results-vector/*.json )
shopt -u nullglob

out="vector-ui/data.js"
{
    printf '// Generated by vector-ui/build -- do not edit by hand. Run ./vector-ui/build to refresh.\n'
    printf 'window.VECTORBENCH_DATA = [\n'
    first=1
    for f in "${files[@]}"; do
        [[ $first -eq 0 ]] && printf ',\n'
        first=0
        jq -c --arg src "$f" '. + {_source: $src}' "$f"
    done
    printf '\n];\n'
} > "$out"

echo "wrote $out from ${#files[@]} result file(s)" >&2
